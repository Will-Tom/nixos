(defvar modetext "normal")

(defwindow mode-indicator
  :monitor 0
  :geometry (geometry :x "20px" :y "20px" :width "90px" :height "28px" :anchor "bottom right")
  :stacking "overlay"
  :exclusive false
  :focusable false
  (box :class "mode-box" :halign "center" :valign "center"
    (label :class "mode-label" :text modetext)))
